{
  "name": "truekart",
  "version": "1.7.0",
  "description": "Real product photos. Best prices. Compare on Myntra, Flipkart, Meesho & Nykaa — spot AI images and shop smarter.",
  "private": true,
  "license": "UNLICENSED",
  "author": "TrueKart",
  "homepage": "https://github.com/yshraj/ai-product-image-detector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yshraj/ai-product-image-detector.git"
  },
  "bugs": {
    "url": "https://github.com/yshraj/ai-product-image-detector/issues"
  },
  "scripts": {
    "validate": "node scripts/validate.js",
    "test": "playwright test",
    "test:unit": "node --test test/unit/*.test.cjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "HEADLESS=0 playwright test --headed",
    "test:headed": "HEADLESS=0 playwright test --headed",
    "test:report": "playwright show-report playwright-report",
    "test:qa-screenshots": "node scripts/capture-qa-screenshots.cjs",
    "lint": "node scripts/validate.js",
    "lint:firefox": "web-ext lint --source-dir .",
    "start": "web-ext run --target chromium --source-dir .",
    "build": "web-ext build --source-dir . --artifacts-dir dist --overwrite-dest",
    "refresh-exifr": "curl -sL -o libs/exifr.min.js https://cdn.jsdelivr.net/npm/exifr/dist/lite.umd.js",
    "refresh-transformers": "curl -fsSL -o libs/transformers.min.js https://cdn.jsdelivr.net/npm/@xenova/transformers@2.17.2/dist/transformers.min.js",
    "refresh-icons": "python3 scripts/generate-icons.py"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "web-ext": "^8.3.0"
  }
}
