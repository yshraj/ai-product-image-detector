{
  "name": "realmodel-filter",
  "version": "1.0.0",
  "description": "Chrome extension that detects AI-generated product images on Myntra, Flipkart, Meesho, and Nykaa.",
  "private": true,
  "scripts": {
    "validate": "node scripts/validate.js",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:headed": "playwright test --headed",
    "lint": "node scripts/validate.js",
    "lint:firefox": "web-ext lint --source-dir .",
    "start": "web-ext run --target chromium --source-dir .",
    "build": "web-ext build --source-dir . --artifacts-dir dist --overwrite-dest",
    "refresh-exifr": "curl -sL -o libs/exifr.min.js https://cdn.jsdelivr.net/npm/exifr/dist/lite.umd.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "web-ext": "^8.3.0"
  }
}
